#!/bin/bash
# Pre-commit hook: sync versions + run CI checks

# Ensure PATH includes common tool locations
export PATH="$HOME/.bun/bin:$HOME/.local/bin:$HOME/.nvm/versions/node/$(ls $HOME/.nvm/versions/node 2>/dev/null | tail -1)/bin:/usr/local/bin:/opt/homebrew/bin:$PATH"

ROOT_DIR="$(git rev-parse --show-toplevel)"

# Sync versions if root package.json changed
if git diff --cached --name-only | grep -q "^package.json$"; then
  echo "package.json changed, syncing versions..."

  VERSION=$(jq -r '.version' "$ROOT_DIR/package.json")

  # Sync to extension package.json
  jq --arg v "$VERSION" '.version = $v' "$ROOT_DIR/apps/extension/package.json" > tmp.json
  mv tmp.json "$ROOT_DIR/apps/extension/package.json"
  git add "$ROOT_DIR/apps/extension/package.json"

  # Sync to wxt.config.ts (manifest version)
  sed -i '' "s/version: '.*'/version: '$VERSION'/" "$ROOT_DIR/apps/extension/wxt.config.ts"
  git add "$ROOT_DIR/apps/extension/wxt.config.ts"

  # Sync to server Cargo.toml (macOS-compatible sed)
  sed -i '' "s/^version = \".*\"/version = \"$VERSION\"/" "$ROOT_DIR/apps/server/Cargo.toml"
  git add "$ROOT_DIR/apps/server/Cargo.toml"

  echo "Synced version $VERSION to all packages"
fi

# Run CI checks on extension changes
if git diff --cached --name-only | grep -q "^apps/extension/"; then
  echo "Running CI checks..."
  cd "$ROOT_DIR/apps/extension"

  echo "→ TypeScript check..."
  bun run typecheck || { echo "❌ Typecheck failed"; exit 1; }

  echo "→ Lint..."
  bun run lint || { echo "❌ Lint failed"; exit 1; }

  echo "→ Unit tests..."
  bun run test || { echo "❌ Tests failed"; exit 1; }

  echo "✅ All checks passed"
fi

{
  "name": "@order-wizard/extension",
  "private": true,
  "version": "1.0.4",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "build": "wxt build",
    "build:local": "wxt build && rm -rf /mnt/c/order-wizard-ext && cp -r .output/chrome-mv3 /mnt/c/order-wizard-ext",
    "zip": "wxt zip",
    "lint": "biome lint",
    "lint:fix": "biome lint --write",
    "format": "biome format --write",
    "typecheck": "wxt prepare && tsc --noEmit",
    "clean": "rm -rf .output dist"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.90.20",
    "clsx": "^2.1.1",
    "exceljs": "^4.4.0",
    "jspdf": "^4.2.0",
    "jspdf-autotable": "^5.0.7",
    "ky": "^1.14.2",
    "lucide-react": "^0.545.0",
    "match-sorter": "^8.2.0",
    "oauth4webapi": "^3.8.3",
    "papaparse": "^5.5.3",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "tailwind-merge": "^3.4.0",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.12",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/chrome": "^0.1.36",
    "@types/node": "^24.10.9",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.2.9",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@wxt-dev/module-react": "^1.2.1",
    "tailwindcss": "^4.1.18",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "wxt": "^0.20.18"
  }
}
